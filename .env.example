# MiMo API 配置（必填）
# 从 platform.xiaomimimo.com 获取你的 API Key
MIMO_API_KEY=sk-你的API密钥

# MiMo API 地址（默认即可）
MIMO_BASE_URL=https://api.xiaomimimo.com/v1

# 模型选择
# 快速问答用: mimo-v2-flash（默认）
# 深度推理用: mimo-v2-pro（旗舰推理模型, 1M上下文）
# 多模态用: mimo-v2-omni（支持图片）
# 最新版:   mimo-v2.5-pro 或 mimo-v2.5
MIMO_MODEL=mimo-v2-flash
MIMO_REASONING_MODEL=mimo-v2-pro

# 服务器配置
HOST=0.0.0.0
PORT=8000
